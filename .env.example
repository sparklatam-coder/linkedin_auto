# 로그인 방식: "google" 또는 "direct"
LOGIN_METHOD=google

# Google 계정 로그인 (LOGIN_METHOD=google 일 때)
GOOGLE_EMAIL=your_google@gmail.com
GOOGLE_PASSWORD=your_google_password

# LinkedIn 직접 로그인 (LOGIN_METHOD=direct 일 때)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

PROMO_TEXT=홍보할 콘텐츠/서비스에 대한 간단한 설명을 여기에 입력하세요
